# ──────────────────────────────────────────────────────────────────────────────
# CloudShield-Auditor — environment variable reference
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS credentials (local dev only — CI uses OIDC, never static keys) ───────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# ── Lambda runtime environment variables ──────────────────────────────────────

# ARN of the SNS topic that fans out to Slack and email.
# Populated automatically after `make deploy`; find it in the CloudFormation outputs.
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:cloudshield-alerts-production

# CloudWatch namespace for custom metrics (ResourcesAudited, ViolationsFound, AuditDurationMs).
CLOUDWATCH_NAMESPACE=CloudShield/Auditor

# ── GitHub Actions secrets (add these in repo Settings → Secrets) ─────────────

# ARN output by `make bootstrap` or `scripts/bootstrap.sh`.
# GitHub Actions assumes this role via OIDC — no static AWS keys needed in CI.
AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/cloudshield-github-deploy-role

# Slack incoming webhook URL. Create one at:
# https://api.slack.com/apps → Your App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
